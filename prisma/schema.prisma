generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int          @id @default(autoincrement())
  username  String       @unique
  password  String
  role      String
  createdAt DateTime     @default(now())
  answers   UserAnswer[]
}

model Questionnaire {
  id        Int                     @id @default(autoincrement())
  name      String
  junctions QuestionnaireJunction[]
  answers   UserAnswer[]
}

model Question {
  id        Int                     @id @default(autoincrement())
  question  Json
  junctions QuestionnaireJunction[]
  answers   UserAnswer[]
}

model QuestionnaireJunction {
  id              Int           @id @default(autoincrement())
  questionId      Int
  questionnaireId Int
  priority        Int
  question        Question      @relation(fields: [questionId], references: [id])
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id])

  @@unique([questionId, questionnaireId])
}

model UserAnswer {
  id              Int           @id @default(autoincrement())
  userId          Int
  questionId      Int
  questionnaireId Int
  answer          Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  question        Question      @relation(fields: [questionId], references: [id])
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id])

  @@unique([userId, questionId, questionnaireId])
}
